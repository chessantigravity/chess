rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Users Profiles ---
    // Anyone can read user profile summaries (needed for search & matches)
    // Only the authenticated user can edit their own profile card
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Match history subcollection
      // Anyone can read matches for summaries, only the owner can write
      match /matches/{matchId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // --- Friend Requests ---
    // User can read requests if they are the sender or receiver
    // User can create request if authenticated as sender
    // User can update/delete if they are sender or receiver
    match /friendRequests/{requestId} {
      allow read: if request.auth != null && 
        (request.auth.uid == resource.data.senderUid || request.auth.uid == resource.data.receiverUid);
      
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.senderUid;
      
      allow update, delete: if request.auth != null && 
        (request.auth.uid == resource.data.senderUid || request.auth.uid == resource.data.receiverUid);
    }

    // --- Friends List ---
    // User can read/write friend relations if their UID is part of the pair
    match /friends/{friendId} {
      allow read: if request.auth != null && 
        (request.auth.uid == resource.data.uidA || request.auth.uid == resource.data.uidB);
      
      allow create: if request.auth != null && 
        (request.auth.uid == request.resource.data.uidA || request.auth.uid == request.resource.data.uidB);
      
      allow update, delete: if request.auth != null && 
        (request.auth.uid == resource.data.uidA || request.auth.uid == resource.data.uidB);
    }

    // --- Notifications ---
    // User can only read/update notifications addressed to them
    // Anyone can create notifications (needed to notify friends)
    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth != null && 
        request.auth.uid == resource.data.userId;
      
      allow create: if request.auth != null;
    }

    // --- Online Rooms (Matchmaking / private codes) ---
    // Authenticated users can host or join matches
    match /online_rooms/{roomCode} {
      allow read, write: if request.auth != null;
    }

    match /matchmaking_queue/{userId} {
      allow read, write: if request.auth != null;
    }
  }
}
